---
import Icon from "./Icon.astro";

interface Props {
  href: string;
  icon: string;
  title: string;
  desc: string;
}
const { href, icon, title, desc } = Astro.props;
---

<a href={href} class="group relative block bg-white p-7 rounded-3xl border border-border/60 hover:border-brand-accent/40 hover:shadow-2xl hover:shadow-brand-charcoal/10 hover:-translate-y-1 transition-all duration-300">
  <div class="w-14 h-14 rounded-2xl bg-brand-cream-dark group-hover:bg-brand-accent transition-colors flex items-center justify-center mb-5">
    <Icon name={icon} class="w-7 h-7 text-brand-charcoal group-hover:text-white transition-colors" />
  </div>
  <h3 class="text-xl font-bold mb-2.5 tracking-tight">{title}</h3>
  <p class="text-muted-foreground leading-relaxed text-[15px]">{desc}</p>
  <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-accent opacity-0 group-hover:opacity-100 translate-x-0 group-hover:translate-x-1 transition-all">
    Learn more
    <Icon name="arrow-right" class="w-4 h-4" />
  </div>
</a>
