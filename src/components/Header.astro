---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import { SITE, NAV } from "../data/site";

// Highlight the active top-level nav item.
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 bg-brand-charcoal text-brand-cream transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center" aria-label={`${SITE.name} — home`}>
      <Logo />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {NAV.map((n) => (
        <a
          href={n.href}
          class:list={[
            "px-4 py-2 rounded-full text-sm font-semibold transition-colors hover:bg-white/10",
            isActive(n.href) && "bg-white/10",
          ]}
          aria-current={isActive(n.href) ? "page" : undefined}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={SITE.phoneHref} class="hidden sm:inline-flex items-center gap-2 bg-brand-accent hover:bg-brand-accent-dark text-brand-accent-contrast font-bold px-5 py-2.5 rounded-[var(--radius-btn)] transition-all hover:shadow-lg hover:shadow-brand-accent/40 hover:-translate-y-0.5">
        <Icon name="phone" class="w-4 h-4" />
        <span class="font-display">{SITE.phone}</span>
      </a>
      <button id="mobile-menu-btn" class="lg:hidden p-2" aria-label="Menu" aria-expanded="false">
        <Icon name="menu" class="w-6 h-6" id="icon-menu" />
        <Icon name="x" class="w-6 h-6 hidden" id="icon-close" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 bg-brand-charcoal">
    <nav class="px-4 py-4 flex flex-col gap-1">
      {NAV.map((n) => (
        <a href={n.href} class="mobile-nav-link py-3 px-3 font-semibold text-sm hover:bg-white/5 rounded-xl">{n.label}</a>
      ))}
      <a href={SITE.phoneHref} class="mt-2 inline-flex items-center justify-center gap-2 bg-brand-accent text-brand-accent-contrast font-bold px-4 py-3 rounded-[var(--radius-btn)]">
        <Icon name="phone" class="w-4 h-4" />
        {SITE.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  // Scroll-aware header
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (window.scrollY > 12) {
      header?.classList.add("backdrop-blur-xl", "shadow-[0_8px_30px_rgb(0,0,0,0.12)]", "bg-brand-charcoal/90");
      header?.classList.remove("bg-brand-charcoal");
    } else {
      header?.classList.remove("backdrop-blur-xl", "shadow-[0_8px_30px_rgb(0,0,0,0.12)]", "bg-brand-charcoal/90");
      header?.classList.add("bg-brand-charcoal");
    }
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Mobile menu toggle
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  const closeMenu = () => {
    mobileMenu?.classList.add("hidden");
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    menuBtn?.setAttribute("aria-expanded", "false");
  };

  menuBtn?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.toggle("hidden");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    menuBtn?.setAttribute("aria-expanded", String(!isHidden));
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
