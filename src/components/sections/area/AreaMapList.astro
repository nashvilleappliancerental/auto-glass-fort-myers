---
// AREA variant: Google Maps embed (desktop) + clickable city list.
import Icon from "../../Icon.astro";
import { cityState } from "../../../data/site";
import type { AreaLocation, MapPin } from "../types";
// `pins` stays in the contract (other variants/callers pass it) but this
// variant now shows a real map embed instead of decorative pins.
interface Props { locations: AreaLocation[]; pins: MapPin[] }
const { locations } = Astro.props;
---
<section id="area" class="py-24 sm:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="max-w-2xl mb-12">
      <p class="text-brand-accent font-bold uppercase tracking-[0.2em] text-xs mb-3">Service area</p>
      <h2 class="text-4xl sm:text-5xl font-extrabold mb-5 tracking-tight leading-[1.05]">Proudly serving {cityState} & the surrounding area.</h2>
      <p class="text-lg text-muted-foreground leading-relaxed">Based in {cityState}, we serve drivers and businesses across the area.</p>
    </div>
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
      <div class="relative hidden lg:block rounded-3xl overflow-hidden bg-brand-charcoal border border-white/10 lg:min-h-full min-h-[420px]">
        <iframe
          title={`Map of ${cityState} service area — Fort Myers Beach, FL`}
          src="https://www.google.com/maps?q=Fort%20Myers%20Beach,%20FL&output=embed"
          class="absolute inset-0 w-full h-full"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
      <div class="flex flex-col">
        <ul class="flex-1 divide-y divide-border/60">
          {locations.map((l) => (
            <li>
              <a href={l.href} class="group flex items-center gap-4 py-4">
                <span class="w-10 h-10 shrink-0 rounded-xl bg-brand-accent/10 flex items-center justify-center group-hover:bg-brand-accent/20 transition-colors">
                  <Icon name="map-pin" class="w-5 h-5 text-brand-accent" />
                </span>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold tracking-tight group-hover:text-brand-accent transition-colors">{l.city}, {l.state}</h3>
                  <p class="text-sm text-muted-foreground leading-snug truncate">{l.summary}</p>
                </div>
                <Icon name="arrow-right" class="w-4 h-4 text-brand-accent shrink-0 transition-transform group-hover:translate-x-1" />
              </a>
            </li>
          ))}
        </ul>
        <a href="/service-area" class="mt-6 inline-flex items-center gap-1.5 font-semibold text-brand-accent hover:gap-2.5 transition-all">
          See all service areas <Icon name="arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</section>
