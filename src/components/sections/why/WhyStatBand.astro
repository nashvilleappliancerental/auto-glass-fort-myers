---
// WHY variant: dark band with a 4-up grid of trust cards (proof-forward).
import Icon from "../../Icon.astro";
import type { TrustItem } from "../types";
interface Props { items: TrustItem[] }
const { items } = Astro.props;
---
<section id="why" class="py-24 sm:py-28 bg-brand-charcoal text-brand-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="max-w-2xl mb-14">
      <p class="text-brand-accent font-bold uppercase tracking-[0.2em] text-xs mb-3">Why choose us</p>
      <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.05] tracking-tight">The local crew you can trust.</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {items.map((t) => (
        <div class="bg-white/[0.04] border border-white/10 rounded-3xl p-7">
          <div class="w-12 h-12 rounded-2xl bg-brand-accent/15 flex items-center justify-center mb-5">
            <Icon name={t.icon} class="w-6 h-6 text-brand-accent" />
          </div>
          <h3 class="font-bold text-lg mb-2 tracking-tight">{t.title}</h3>
          <p class="text-sm text-brand-cream/70 leading-relaxed mb-4">{t.desc}</p>
          <div class="inline-flex items-center gap-1.5 rounded-full border border-brand-accent/30 bg-brand-accent/5 px-3 py-1.5">
            <Icon name="badge-check" class="w-3.5 h-3.5 text-brand-accent" />
            <span class="text-xs font-semibold text-brand-cream">{t.proof}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
