---
// WHY variant: sticky heading on the left, stacked editorial rows on the right.
import Icon from "../../Icon.astro";
import type { TrustItem } from "../types";
interface Props { items: TrustItem[] }
const { items } = Astro.props;
---
<section id="why" class="py-24 sm:py-28 bg-brand-cream-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-[0.85fr_1.4fr] gap-12 lg:gap-16">
      <div class="lg:sticky lg:top-28 self-start">
        <p class="text-brand-accent font-bold uppercase tracking-[0.2em] text-xs mb-3">Why choose us</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold leading-[1.05] tracking-tight mb-5">The local crew you can trust.</h2>
        <p class="text-muted-foreground leading-relaxed max-w-sm">
          No call centers, no subcontracted crews, no high-pressure sales — just an insured local team that does the job right and stands behind it.
        </p>
        <a href="/contact" class="mt-6 inline-flex items-center gap-1.5 font-semibold text-brand-accent hover:gap-2.5 transition-all">
          Get a free estimate <Icon name="arrow-right" class="w-4 h-4" />
        </a>
      </div>
      <div class="divide-y divide-border/60">
        {items.map((t) => (
          <div class="flex items-start gap-5 py-7 first:pt-0">
            <div class="w-12 h-12 shrink-0 rounded-2xl bg-brand-accent/10 flex items-center justify-center">
              <Icon name={t.icon} class="w-6 h-6 text-brand-accent" />
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between gap-4 flex-wrap mb-1.5">
                <h3 class="font-bold text-lg tracking-tight">{t.title}</h3>
                <span class="inline-flex items-center gap-1.5 rounded-full border border-brand-accent/30 bg-brand-accent/5 px-3 py-1">
                  <Icon name="badge-check" class="w-3.5 h-3.5 text-brand-accent" />
                  <span class="text-xs font-semibold text-brand-charcoal">{t.proof}</span>
                </span>
              </div>
              <p class="text-muted-foreground leading-relaxed">{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
