---
// SERVICES variant: compact 4-up icon cards.
import ServiceCard from "../../ServiceCard.astro";
import { SITE, tradeCap, cityState } from "../../../data/site";
import type { ServiceItem } from "../types";
interface Props { services: ServiceItem[] }
const { services } = Astro.props;
---
<section id="services" class="relative overflow-hidden py-24 sm:py-28 bg-brand-charcoal text-brand-cream">
  <img
    src="/images/why-fort-myers-aerial-view.webp"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-charcoal via-brand-charcoal/88 to-brand-charcoal/64"></div>
  <div class="absolute inset-0 bg-brand-charcoal/20"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
      <div>
        <p class="text-brand-accent font-bold uppercase tracking-[0.2em] text-xs mb-3">What we do</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight max-w-xl leading-[1.05]">{tradeCap} work, done right.</h2>
      </div>
      <p class="text-brand-cream/72 max-w-md leading-relaxed">
        Mobile {SITE.trade} across {cityState} and the surrounding area. We come to you.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((s) => (
        <ServiceCard href={`/${s.id}`} icon={s.icon} title={s.title} desc={s.summary} />
      ))}
    </div>
  </div>
</section>
