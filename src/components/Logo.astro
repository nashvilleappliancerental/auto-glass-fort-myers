---
// Brand logo lockup: mark + wordmark from SITE.logo ({ eyebrow, main, accent }).
// Built for dark (charcoal) backgrounds — the mark outline + main wordmark use
// currentColor (cream), the mark joint + accent word use the brand accent.
// The `brand` skill swaps the placeholder mark below for the real logo mark.
import { SITE } from "../data/site";
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
const { eyebrow, main, accent } = SITE.logo;
---

<span class={`inline-flex items-center gap-2.5 text-brand-cream ${className}`}>
  <svg viewBox="0 0 90 90" fill="none" class="w-9 h-9 sm:w-10 sm:h-10 shrink-0" aria-hidden="true">
    <!-- Windshield outline -->
    <path d="M26 32 Q45 27 64 32 L70 60 Q45 66 20 60 Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
    <!-- Shine sparkle (tilted 22.5deg) -->
    <path d="M57 32 L59.5 38.5 L66 41 L59.5 43.5 L57 50 L54.5 43.5 L48 41 L54.5 38.5 Z" fill="var(--color-brand-accent)" transform="rotate(22.5 57 41)" />
  </svg>
  <span class="flex flex-col leading-none">
    <span class="text-[0.6rem] font-bold tracking-[0.28em] text-brand-cream/65">{eyebrow}</span>
    <span class="font-display font-extrabold text-lg sm:text-xl tracking-tight leading-tight mt-1">{main} <span class="text-brand-accent">{accent}</span></span>
  </span>
</span>
