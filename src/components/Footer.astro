---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import { SITE, NAV, tradeCap, cityState } from "../data/site";
import { getCollection } from "astro:content";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
const year = new Date().getFullYear();
---

<footer class="bg-brand-charcoal text-brand-cream/80 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-4 gap-10">
    <div class="md:col-span-1">
      <div class="mb-4">
        <Logo />
      </div>
      <p class="text-sm leading-relaxed max-w-sm">
        Locally owned, mobile {SITE.trade} service proudly serving {cityState} and the surrounding area.
      </p>
      <a
        href="https://guidetoflorida.com/fort-myers/automotive-transportation/auto-glass-fort-myers?from=badge"
        title="Best of Florida Nominee — Guide to Florida"
        target="_blank"
        rel="noopener"
        class="inline-block mt-6 transition-opacity hover:opacity-80"
      >
        <img
          src="/images/badge-guide-to-florida.webp"
          alt="Best of Florida Nominee — Guide to Florida"
          width="112"
          height="112"
          loading="lazy"
          class="w-28 h-28"
        />
      </a>
    </div>

    <div>
      <h4 class="font-bold text-brand-cream uppercase text-xs tracking-[0.2em] mb-4">Services</h4>
      <ul class="space-y-2.5 text-sm">
        {services.map((s) => (
          <li><a href={`/${s.id}`} class="hover:text-brand-accent transition-colors">{s.data.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-bold text-brand-cream uppercase text-xs tracking-[0.2em] mb-4">Company</h4>
      <ul class="space-y-2.5 text-sm">
        {NAV.map((n) => (
          <li><a href={n.href} class="hover:text-brand-accent transition-colors">{n.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-bold text-brand-cream uppercase text-xs tracking-[0.2em] mb-4">Contact</h4>
      <a href={SITE.phoneHref} class="block font-display font-bold text-2xl text-brand-accent mb-2">{SITE.phone}</a>
      <a href={`mailto:${SITE.email}`} class="block text-sm hover:text-brand-accent break-all mb-3">{SITE.email}</a>
      {SITE.hours.map((h) => (
        <p class="text-sm"><span class="text-brand-cream/60">{h.day}:</span> {h.time}</p>
      ))}
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5 text-xs text-brand-cream/60 flex flex-col sm:flex-row items-center justify-center gap-x-3 gap-y-1 text-center">
      <span>© {year} {SITE.name}. All Rights Reserved. {tradeCap} in {cityState}.</span>
      <span class="hidden sm:inline text-brand-cream/30">·</span>
      <a href="/sitemap" class="hover:text-brand-accent transition-colors">Site Map</a>
    </div>
  </div>
</footer>
