---
// Centralized icon set. Usage: <Icon name="phone" class="w-5 h-5" />
// Stroke icons inherit currentColor; "star" and "sparkle" are filled.
interface Props {
  name: string;
  class?: string;
  [key: string]: unknown;
}
const { name, class: className = "w-5 h-5", ...rest } = Astro.props;

const filled = new Set(["star", "sparkle"]);
const isFilled = filled.has(name);
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill={isFilled ? "currentColor" : "none"}
  stroke={isFilled ? undefined : "currentColor"}
  stroke-width={isFilled ? undefined : 2}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  {...rest}
>
  {name === "hammer" && (
    <Fragment>
      <path d="M15 12l-8.5 8.5a2.12 2.12 0 0 1-3-3L12 9" />
      <path d="M17.64 15L22 10.64" />
      <path d="M20.91 11.7l-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91z" />
    </Fragment>
  )}
  {/* Common service-trade icons (towing/auto/utility). Add more per trade as needed. */}
  {name === "truck" && (
    <Fragment>
      <path d="M10 17h4V5H2v12h3" />
      <path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1" />
