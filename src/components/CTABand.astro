---
import Icon from "./Icon.astro";
import { SITE } from "../data/site";

interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Ready for a free estimate?",
  text = "Call now or request your free, no-obligation estimate. We respond within one business day.",
} = Astro.props;
---

<section class="py-20 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="relative overflow-hidden rounded-[2rem] bg-brand-charcoal text-brand-cream px-6 py-12 sm:px-12 sm:py-14">
      <div class="pointer-events-none absolute -top-24 -right-24 w-80 h-80 rounded-full bg-brand-accent/25 blur-[120px]"></div>
      <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
        <div class="max-w-xl">
          <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-[1.1] mb-3">{heading}</h2>
          <p class="text-brand-cream/75 leading-relaxed">{text}</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-brand-accent hover:bg-brand-accent-dark text-brand-accent-contrast font-bold text-base px-7 py-4 rounded-[var(--radius-btn)] transition-all hover:shadow-2xl hover:shadow-brand-accent/40 hover:-translate-y-0.5">
            Get a Free Estimate
            <Icon name="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a href={SITE.phoneHref} class="inline-flex items-center justify-center gap-2 bg-white/5 hover:bg-white/10 backdrop-blur border border-white/20 text-white font-semibold text-base px-7 py-4 rounded-[var(--radius-btn)] transition-colors">
            <Icon name="phone" class="w-5 h-5" />
            {SITE.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
