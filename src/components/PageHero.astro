---
import Icon from "./Icon.astro";

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumbs?: Crumb[];
  image?: string;
}
const { eyebrow, title, subtitle, crumbs = [], image } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-charcoal text-brand-cream">
  {image && (
    <Fragment>
      <img src={image} alt="" aria-hidden="true" loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-charcoal via-brand-charcoal/85 to-brand-charcoal/45"></div>
    </Fragment>
  )}
  <div class="pointer-events-none absolute -top-32 -left-32 w-[460px] h-[460px] rounded-full bg-brand-accent/25 blur-[120px]"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-16 pb-16 sm:pt-20 sm:pb-20">
    {crumbs.length > 0 && (
      <nav class="flex items-center flex-wrap gap-1.5 text-xs text-brand-cream/60 mb-6" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <Fragment>
            {c.href ? <a href={c.href} class="hover:text-brand-accent transition-colors">{c.label}</a> : <span class="text-brand-cream/80">{c.label}</span>}
            {i < crumbs.length - 1 && <span class="opacity-50">/</span>}
          </Fragment>
        ))}
      </nav>
    )}
    {eyebrow && <p class="text-brand-accent font-bold uppercase tracking-[0.2em] text-xs mb-3">{eyebrow}</p>}
    <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl leading-[1.04] tracking-tight max-w-3xl">{title}</h1>
    {subtitle && <p class="text-lg text-brand-cream/75 mt-5 max-w-2xl leading-relaxed">{subtitle}</p>}
  </div>
</section>
